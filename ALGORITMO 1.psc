Algoritmo Calculo_de_la_energia_relativa
	Definir m,c,e Como Real
	c <- 299792458
	
	Escribir "calculo de energia relativa (E=mc^2)"
	Escribir "===================================="
	Escribir "ingresa la masa en Kg: "
	leer m
	
	e <- m * (c*c)
	Escribir "===================================="
	Escribir " E es igual a :",e," julios"
	
FinAlgoritmo
